{
  "title": "Per-Host Drilldown",
  "uid": "per-host",
  "tags": ["OS-nixCfg", "host"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": {
          "query": "label_values(up{job=\"node\"}, instance)",
          "refId": "host"
        },
        "current": {},
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU by mode",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{instance=\"$host\"}[5m]))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "timeseries",
      "title": "Memory breakdown",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"$host\"}",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=\"$host\"}",
          "legendFormat": "available",
          "refId": "B"
        },
        {
          "expr": "node_memory_Cached_bytes{instance=\"$host\"}",
          "legendFormat": "cached",
          "refId": "C"
        },
        {
          "expr": "node_memory_Buffers_bytes{instance=\"$host\"}",
          "legendFormat": "buffers",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "Disk usage by mountpoint (%)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - node_filesystem_avail_bytes{instance=\"$host\",fstype!~\"tmpfs|fuse.*|overlay\"} / node_filesystem_size_bytes{instance=\"$host\",fstype!~\"tmpfs|fuse.*|overlay\"})",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "type": "timeseries",
      "title": "Network throughput",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=\"$host\",device!~\"lo|docker.*|br-.*|veth.*\"}[5m])",
          "legendFormat": "rx {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=\"$host\",device!~\"lo|docker.*|br-.*|veth.*\"}[5m])",
          "legendFormat": "tx {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "type": "table",
      "title": "Failed systemd units",
      "id": 5,
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_systemd_unit_state{instance=\"$host\",state=\"failed\"} == 1",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Recent journal (last 1h)",
      "id": 6,
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{host=\"$host\"}", "refId": "A" }],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true
      }
    }
  ]
}
