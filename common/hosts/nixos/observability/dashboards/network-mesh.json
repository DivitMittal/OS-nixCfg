{
  "title": "Network Mesh",
  "uid": "network-mesh",
  "tags": ["OS-nixCfg", "network"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Mesh reachability (% success)",
      "id": 1,
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(probe_success{job=\"blackbox-icmp\"}) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Cert expiry (days, min across fleet)",
      "id": 2,
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "min((probe_ssl_earliest_cert_expiry - time()) / 86400)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 14 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "DNS resolution (% success)",
      "id": 3,
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(probe_success{job=\"blackbox-dns\"}) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "options": { "colorMode": "background" }
    },
    {
      "type": "timeseries",
      "title": "Mesh ping RTT per host (ms)",
      "id": 4,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_icmp_duration_seconds{job=\"blackbox-icmp\",phase=\"rtt\"} * 1000",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "table",
      "title": "Cert expiry per HTTPS target",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "Days until expiry", "instance": "URL" }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Days until expiry" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 14 },
                    { "color": "green", "value": 60 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "TCP probe status",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-tcp\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
