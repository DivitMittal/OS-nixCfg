{
  "title": "Nix Health",
  "uid": "nix-health",
  "tags": ["OS-nixCfg", "nix"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "bargauge",
      "title": "Nix store size per host",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nix_store_size_bytes",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "showUnfilled": true
      }
    },
    {
      "type": "timeseries",
      "title": "Store size growth (30d)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nix_store_size_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "table",
      "title": "Rebuild & flake-lock age (per host)",
      "id": 3,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(time() - nix_last_rebuild_timestamp_seconds) / 86400",
          "format": "table",
          "instant": true,
          "refId": "rebuild_age"
        },
        {
          "expr": "nix_flake_lock_age_seconds / 86400",
          "format": "table",
          "instant": true,
          "refId": "lock_age"
        },
        {
          "expr": "nix_generations_total",
          "format": "table",
          "instant": true,
          "refId": "generations"
        },
        {
          "expr": "nix_gc_roots_total",
          "format": "table",
          "instant": true,
          "refId": "gc_roots"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #rebuild_age": "Last rebuild (days ago)",
              "Value #lock_age": "Flake lock age (days)",
              "Value #generations": "Generations retained",
              "Value #gc_roots": "GC roots"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Last rebuild (days ago)" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 14 },
                    { "color": "red", "value": 30 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Flake lock age (days)" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 7 },
                    { "color": "red", "value": 14 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "heatmap",
      "title": "Rebuild duration distribution (7d)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(nixos_rebuild_duration_seconds_bucket[7d])) by (le)",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rebuild duration P95 per host",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (instance, le) (rate(nixos_rebuild_duration_seconds_bucket[7d])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Time since last GC (per host)",
      "id": 6,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(time() - nix_last_gc_timestamp_seconds) / 86400",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 14 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    }
  ]
}
